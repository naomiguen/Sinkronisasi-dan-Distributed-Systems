
# Services
REDIS_URL=redis://localhost:6379/0
# Use placeholders for credentials to avoid accidental real secrets
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/distributed_db

# Service binding
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001

# Node/runtime
NODE_NAME=node-1
LOG_LEVEL=INFO

# Application secret 
# Replace with a secure random value in your local .env
SECRET_KEY=REPLACE_ME_WITH_RANDOM_SECRET

# Repository info (helpful for docs/scripts)
GIT_REPO=https://github.com/naomiguen/Sinkronisasi-dan-Distributed-Systems
# NODE CONFIGURATION

# Node ID (1, 2, 3, dst)
NODE_ID=1

# Host untuk bind (0.0.0.0 untuk semua interface)
NODE_HOST=0.0.0.0

# Port untuk API dan Raft RPC
NODE_PORT=8001

# CLUSTER CONFIGURATION

# Semua node dalam cluster (format: host:port,host:port,...)
# Untuk Docker: node-1:8001,node-2:8002,node-3:8003
# Untuk local: localhost:8001,localhost:8002,localhost:8003
CLUSTER_NODES=node-1:8001,node-2:8002,node-3:8003

# REDIS CONFIGURATION

# Redis host
# Docker: redis
# Local: localhost
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379



# Redis database number
REDIS_DB=0


# RAFT CONSENSUS CONFIGURATION

# Election timeout range (ms) - waktu sebelum follower menjadi candidate
RAFT_ELECTION_TIMEOUT_MIN=150
RAFT_ELECTION_TIMEOUT_MAX=300

# Heartbeat interval (ms) - seberapa sering leader mengirim heartbeat
RAFT_HEARTBEAT_INTERVAL=50

# RPC timeout (ms) - timeout untuk RPC antar node
RAFT_RPC_TIMEOUT=1000


# LOCK MANAGER CONFIGURATION

# Default TTL untuk lock (detik)
LOCK_DEFAULT_TTL=30

# Maximum TTL untuk lock (detik)
LOCK_MAX_TTL=300

# Retry interval untuk acquire lock (detik)
LOCK_RETRY_INTERVAL=1

# Maximum retries untuk acquire lock
LOCK_MAX_RETRIES=10


# CACHE CONFIGURATION

# Maximum ukuran cache (jumlah entry)
CACHE_MAX_SIZE=1000

# Cache TTL default (detik), -1 untuk tidak expire
CACHE_DEFAULT_TTL=-1

# Cache replacement policy (LRU atau LFU)
CACHE_REPLACEMENT_POLICY=LRU

# MONITORING & METRICS
# Enable metrics collection
METRICS_ENABLED=true

# Metrics port (beda dari API port)
METRICS_PORT=9091


# LOGGING
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# NETWORK

# Enable/disable failure detection
FAILURE_DETECTION_ENABLED=true

# Ping interval untuk failure detection (detik)
FAILURE_DETECTION_PING_INTERVAL=1


# DEVELOPMENT SETTINGS

# Debug mode
DEBUG=false